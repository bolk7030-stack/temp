#!/bin/sh

set -u

echo "================================================="
echo " WireGuard OpenWrt Debug Installer"
echo "================================================="

run() {
  echo
  echo ">>> $*"
  "$@"
  rc=$?
  echo "<<< exit code: $rc"
  return $rc
}

show_debug() {
  echo
  echo "================ DEBUG STATE ================"

  echo
  echo "[System]"
  uname -a || true
  cat /etc/os-release || true

  echo
  echo "[Packages]"
  apk info | grep -i wireguard || true
  apk info | grep -i curl || true

  echo
  echo "[Kernel modules]"
  lsmod | grep -i wireguard || true
  lsmod | grep -i udp_tunnel || true
  lsmod | grep -i curve || true

  echo
  echo "[UCI network wg0]"
  uci show network | grep -E 'wg0|wireguard' || true

  echo
  echo "[UCI firewall vpn]"
  uci show firewall | grep -E 'vpn|forwarding' || true

  echo
  echo "[Interfaces]"
  ip link show || true

  echo
  echo "[Routes IPv4]"
  ip route show || true

  echo
  echo "[Routes IPv6]"
  ip -6 route show || true

  echo
  echo "[wg show]"
  wg show || true

  echo
  echo "[Network logs]"
  logread | grep -Ei 'wg|wireguard|netifd|proto' | tail -80 || true

  echo "============== END DEBUG STATE =============="
}

trap 'echo; echo "SCRIPT FAILED NEAR LINE $LINENO"; show_debug' ERR

echo
echo "[1/6] Installing WireGuard..."
run apk update
run apk add wireguard-tools kmod-wireguard curl

echo
echo "[2/6] Verifying WireGuard tools..."
run which wg
wg --version || true

echo
echo "[3/6] Loading/checking kernel module..."
modprobe wireguard 2>/dev/null || true
lsmod | grep -i wireguard || echo "WARNING: wireguard module not visible in lsmod"

echo
echo "[4/6] Configuring wg0..."

uci -q delete network.wg0 || true
uci -q delete network.wg0_peer || true

uci set network.wg0=interface
uci set network.wg0.proto='wireguard'
uci set network.wg0.private_key='KE9+uTrEEwS/cRQXf2rN7drchmQNhQyrxMea9/HapmE='
uci add_list network.wg0.addresses='10.66.25.155/32'
uci add_list network.wg0.addresses='fc00:bbbb:bbbb:bb01::3:199a/128'

uci set network.wg0_peer=wireguard_wg0
uci set network.wg0_peer.interface='wg0'
uci set network.wg0_peer.public_key='MVqe9e9aDwfFuvEhEn4Wd/zWV3cmiCX9fZMWetz+23A='
uci set network.wg0_peer.endpoint_host='185.195.232.70'
uci set network.wg0_peer.endpoint_port='51820'
uci set network.wg0_peer.persistent_keepalive='25'
uci add_list network.wg0_peer.allowed_ips='0.0.0.0/0'
uci add_list network.wg0_peer.allowed_ips='::/0'
uci set network.wg0_peer.route_allowed_ips='1'

echo
echo "[Network config before commit]"
uci show network | grep -E 'wg0|wireguard' || true

echo
echo "[5/6] Configuring firewall..."

uci -q delete firewall.vpn || true
uci -q delete firewall.vpn_forward || true

uci set firewall.vpn=zone
uci set firewall.vpn.name='vpn'
uci add_list firewall.vpn.network='wg0'
uci set firewall.vpn.input='REJECT'
uci set firewall.vpn.output='ACCEPT'
uci set firewall.vpn.forward='REJECT'
uci set firewall.vpn.masq='1'
uci set firewall.vpn.mtu_fix='1'

uci set firewall.vpn_forward=forwarding
uci set firewall.vpn_forward.src='lan'
uci set firewall.vpn_forward.dest='vpn'

echo
echo "[Firewall config before commit]"
uci show firewall | grep -E 'vpn|forwarding' || true

echo
echo "[6/6] Applying..."

run uci commit network
run uci commit firewall

echo
echo "[Restarting services]"
/etc/init.d/network restart || true
sleep 5
/etc/init.d/firewall restart || true
sleep 2

echo
echo "[Manual ifup wg0 attempt]"
ifup wg0 || true
sleep 3

show_debug

echo
echo "Public IP test:"
curl -4 ifconfig.me || true
echo

echo
echo "DONE"
